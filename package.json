{
	"name": "todo-name-the-application",
	"version": "1.0.0",
	"license": "UNLICENSED",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"dev-share": "next dev -H 0.0.0.0",
		"build": "next build",
		"preview": "serve out",
		"type-check": "tsc --noEmit",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test:mutation": "stryker run",
		"lint": "eslint . --fix",
		"lint:check": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"tf:fmt:check": "terraform -chdir=static-site fmt -check -diff",
		"tf:validate": "terraform -chdir=static-site init -backend=false -input=false && terraform -chdir=static-site validate",
		"tf:lint": "tflint --chdir=static-site --init && tflint --chdir=static-site",
		"tf:scan": "trivy config --exit-code 1 static-site",
		"tf:check": "yarn run tf:fmt:check && yarn run tf:validate && yarn run tf:lint && yarn run tf:scan",
		"prepare": "husky"
	},
	"dependencies": {
		"next": "16.2.10",
		"react": "19.2.7",
		"react-dom": "19.2.7"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.3",
		"eslint": "^9",
		"eslint-config-next": "16.2.10",
		"husky": "^9.1.7",
		"jsdom": "^29",
		"lint-staged": "^17.1.0",
		"prettier": "^3.9.4",
		"serve": "^14.2.6",
		"typescript": "^5",
		"vite": "^8.1.3",
		"vitest": "^4.1.9"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		]
	}
}

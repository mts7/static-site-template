{
	"$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
	"packageManager": "yarn",
	"testRunner": "vitest",
	"reporters": ["html", "clear-text", "progress"],
	"mutate": ["src/**/*.ts", "src/**/*.tsx", "!src/**/*.test.ts", "!src/**/*.test.tsx"],
	"thresholds": {
		"high": 80,
		"low": 60,
		"break": null
	}
}
